{
  "name": "contextra",
  "displayName": "Contextra",
  "description": "Contextra reads your prompt's intent and auto-injects only the relevant slices of your codebase — cutting token costs and making AI outputs dramatically more precise.",
  "version": "0.1.0",
  "publisher": "contextra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contextra/contextra-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/contextra/contextra-vscode/issues"
  },
  "homepage": "https://github.com/contextra/contextra-vscode#readme",
  "keywords": [
    "ai",
    "prompt",
    "context",
    "llm",
    "tokens",
    "optimization",
    "copilot"
  ],
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0A1F44",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextra.optimizePrompt",
        "title": "Contextra: Optimize Prompt"
      },
      {
        "command": "contextra.connect",
        "title": "Contextra: Connect Account",
        "icon": "$(sign-in)"
      },
      {
        "command": "contextra.signOut",
        "title": "Contextra: Sign Out",
        "icon": "$(sign-out)"
      },
      {
        "command": "contextra.showStatus",
        "title": "Contextra: Show Status"
      },
      {
        "command": "contextra.focusView",
        "title": "Contextra: Focus View"
      }
    ],
    "keybindings": [
      {
        "command": "contextra.optimizePrompt",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contextra",
          "title": "Contextra",
          "icon": "media/contextra.svg"
        }
      ]
    },
    "views": {
      "contextra": [
        {
          "id": "contextra.view",
          "name": "Contextra",
          "icon": "media/contextra.svg",
          "contextualTitle": "Contextra"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "contextra.view",
        "contents": "Welcome to Contextra.\n\nContextra attaches just the relevant slice of your repo to every prompt — cutting tokens, sharpening answers.\n\n[Connect Account](command:contextra.connect)\n\nAfter signing in on the web, paste the token back here when prompted.\n\n[Show Status](command:contextra.showStatus)",
        "when": "!contextra.isAuthenticated"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "contextra.connect",
          "when": "view == contextra.view && !contextra.isAuthenticated",
          "group": "navigation"
        },
        {
          "command": "contextra.signOut",
          "when": "view == contextra.view && contextra.isAuthenticated",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Contextra",
      "properties": {
        "contextra.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:3000/api",
          "description": "Base URL for the Contextra API. The extension calls POST {base}/optimize and GET {base}/health."
        },
        "contextra.webUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL for the Contextra web app. Used to open the login page when connecting your account."
        },
        "contextra.previewBeforeReplace": {
          "type": "boolean",
          "default": true,
          "description": "Show a preview dialog before replacing the selected text."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "package-vsix": "npx vsce package --out contextra.vsix --allow-missing-repository --no-dependencies",
    "install-local": "npm run package && npm run package-vsix && code --install-extension contextra.vsix --force",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1"
  }
}
